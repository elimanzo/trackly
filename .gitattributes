# Normalize line endings to LF on commit (Windows/Linux/macOS compatibility)
* text=auto eol=lf

# Explicitly enforce LF for SQL — CRLF in migrations/seeds causes noisy diffs
*.sql text eol=lf

# Explicitly binary — never mangle these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
