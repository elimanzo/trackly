# ---------------------------------------------------------------
# Local development (Supabase CLI)
# ---------------------------------------------------------------
# 1. Start the local stack:  pnpm db:start
# 2. Get your keys:          supabase status
# 3. Fill in the values below from the output above
#
# The URL is always http://127.0.0.1:54321
# ANON_KEY and SERVICE_ROLE_KEY are printed by `supabase status`
# ---------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------
# Production (Supabase dashboard → Project Settings → API)
# ---------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
